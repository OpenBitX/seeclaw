{
  "name": "browser_search",
  "description": "在浏览器地址栏中搜索关键词（依赖浏览器已打开）",
  "params": ["query"],
  "triggers": "搜索/查找/search + 关键词",
  "steps": [
    { "action": "hotkey", "args": { "keys": "ctrl+l" } },
    { "action": "wait", "args": { "milliseconds": 200 } },
    { "action": "type_text", "args": { "text": "{query}", "clear_first": true } },
    { "action": "key_press", "args": { "key": "enter" } },
    { "action": "wait", "args": { "milliseconds": 2000 } }
  ]
}
