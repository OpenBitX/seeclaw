{
  "name": "browser_actions",
  "description": "浏览器导航和交互，包括打开 URL、前进后退、刷新、标签页管理",
  "params": ["url"],
  "triggers": "打开网页/浏览/导航/访问/搜索网站/新标签页",
  "steps": [
    { "action": "hotkey", "args": { "keys": "ctrl+l" } },
    { "action": "wait", "args": { "milliseconds": 200 } },
    { "action": "type_text", "args": { "text": "{url}", "clear_first": true } },
    { "action": "key_press", "args": { "key": "enter" } },
    { "action": "wait", "args": { "milliseconds": 2000 } }
  ]
}
