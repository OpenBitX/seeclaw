{
  "name": "file_operations",
  "params": ["path"],
  "steps": [
    { "action": "hotkey", "args": { "keys": "win+e" } },
    { "action": "wait", "args": { "milliseconds": 800 } },
    { "action": "hotkey", "args": { "keys": "ctrl+l" } },
    { "action": "wait", "args": { "milliseconds": 200 } },
    { "action": "type_text", "args": { "text": "{path}", "clear_first": true } },
    { "action": "key_press", "args": { "key": "enter" } },
    { "action": "wait", "args": { "milliseconds": 1000 } }
  ]
}
